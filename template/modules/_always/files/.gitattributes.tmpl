# Auto-detect text files and normalize line endings
* text=auto

# Force LF for scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.pkl binary
*.parquet binary
*.feather binary
*.h5 binary
*.hdf5 binary
*.rds binary
*.rda binary
