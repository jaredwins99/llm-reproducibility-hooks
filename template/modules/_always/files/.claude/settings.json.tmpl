{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(make *)",
      "Bash(python *)",
      "Bash(Rscript *)",
      "Bash(pip install *)",
      "Bash(uv *)",
      "Bash(bash reference/stan/search.sh *)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(git push --force)*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "matcher": "Edit|Write",
        "command": "FILE_PATH=$(echo \"$CLAUDE_TOOL_INPUT\" | grep -oE '\"file_path\"\\s*:\\s*\"[^\"]+\\.stan\"' | grep -oE '[^\"]+\\.stan' | head -1); if [ -n \"$FILE_PATH\" ] && [ -f \"$FILE_PATH\" ]; then echo '=== Stan reference search (auto-fired on .stan edit) ==='; bash reference/stan/search.sh --from-file \"$FILE_PATH\" 2>/dev/null | head -80; fi"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "matcher": "Edit",
        "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.(py|R|r)\"'; then make format 2>/dev/null || true; fi"
      }
    ]
  }
}
