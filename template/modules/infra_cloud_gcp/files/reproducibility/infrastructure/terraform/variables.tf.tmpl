variable "project_name" {
  description = "Name of the project"
  type        = string
  default     = "{{project_name}}"
}

variable "gcp_project_id" {
  description = "GCP project ID"
  type        = string
}

variable "gcp_region" {
  description = "GCP region to deploy resources"
  type        = string
  default     = "us-central1"
}

