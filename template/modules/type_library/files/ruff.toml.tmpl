# Additional ruff rules for library/package projects
# These extend the base ruff.toml with stricter requirements

[lint]
extend-select = [
    "TCH",    # flake8-type-checking (move type-only imports behind TYPE_CHECKING)
    "ANN",    # flake8-annotations (require type hints on public functions)
    "D",      # pydocstyle (require docstrings on public functions/classes)
]

[lint.per-file-ignores]
"correctness/tests/**" = [
    "ANN",    # no type hints required in tests
    "D",      # no docstrings required in tests
]
"scripts/**" = [
    "ANN",    # no type hints required in scripts
    "D100",   # no module docstrings in scripts
]

[lint.pydocstyle]
convention = "numpy"
