{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(make *)",
      "Bash(python *)",
      "Bash(Rscript *)",
      "Bash(pip install *)",
      "Bash(uv *)",
      "Bash(bash reference/stan/search.sh *)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(git push --force)*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "matcher": "Edit|Write",
        "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.stan\"'; then echo 'STAN FILE DETECTED — run bash reference/stan/search.sh --from-file on this file BEFORE editing. Search the reference for the modeling approach. NEVER write Stan from memory.'; fi"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "matcher": "Edit",
        "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.(py|R|r)\"'; then make format 2>/dev/null || true; fi"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "echo '--- Reminder: Follow CLAUDE.md conventions. Code speaks for itself. No what-comments. Em-dash separators. Functions in src/, pipelines in scripts/. Log every data step. ---'"
      }
    ]
  }
}
