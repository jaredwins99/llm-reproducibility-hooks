# DVC Pipeline — Reproducibility tenet
# Run with: dvc repro
# Only re-runs stages whose dependencies changed

stages:
  prepare:
    cmd: python scripts/01_prepare.py
    deps:
      - scripts/01_prepare.py
      - src/{{project_name_py}}/
    outs:
      - data/prepared.parquet

  train:
    cmd: python scripts/02_train.py
    deps:
      - scripts/02_train.py
      - src/{{project_name_py}}/
      - data/prepared.parquet
    outs:
      - models/model.pkl
    metrics:
      - models/metrics.json:
          cache: false

  evaluate:
    cmd: python scripts/03_evaluate.py
    deps:
      - scripts/03_evaluate.py
      - src/{{project_name_py}}/
      - models/model.pkl
      - data/prepared.parquet
    plots:
      - reports/evaluation.csv:
          cache: false
